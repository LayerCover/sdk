# LayerCover SDK Configuration
# Copy this file to .env and fill in the values

# RPC URLs
# Get your API key from: https://www.alchemy.com/ or https://www.infura.io/
RPC_URL=https://base-sepolia.g.alchemy.com/v2/your-api-key-here

# Chain ID (84532 = Base Sepolia, 8453 = Base Mainnet)
CHAIN_ID=84532

# Private key for testing (testnet only, without 0x prefix)
# WARNING: Never use a mainnet private key here
PRIVATE_KEY=

# Subgraph URL (optional — for on-chain data queries)
SUBGRAPH_URL=

# SDK smoke script settings (examples/smoke-testnet.js)
API_BASE_URL=https://app.layercover.com
DEPLOYMENT=base_sepolia_usdc
POOL_ID=1
COVERAGE_AMOUNT_USDC=25
DURATION_WEEKS=4
MAX_RATE_BPS=
REQUEST_TIMEOUT_MS=15000
MAX_RETRIES=2
RETRY_DELAY_MS=300
TX_CONFIRMATIONS=1
TX_WAIT_TIMEOUT_MS=180000
