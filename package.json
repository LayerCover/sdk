{
    "name": "@layercover/sdk",
    "version": "0.5.0",
    "description": "LayerCover SDK for seamless insurance integration",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/esm/react/index.js",
            "require": "./dist/react/index.js"
        },
        "./dist/*": "./dist/*"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "tsc && tsc -p tsconfig.esm.json",
        "build:cjs": "tsc",
        "build:esm": "tsc -p tsconfig.esm.json",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run clean && npm run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:build": "node tests/test-dual-build.mjs",
        "test:legacy": "npx tsx tests/sdk-test.ts",
        "smoke:testnet": "node examples/smoke-testnet.js --dry-run",
        "smoke:testnet:execute": "node examples/smoke-testnet.js --execute",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "npm run build && changeset publish"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/layercover/sdk.git"
    },
    "homepage": "https://docs.layercover.com/sdk",
    "bugs": {
        "url": "https://github.com/layercover/sdk/issues"
    },
    "dependencies": {
        "ethers-v6": "npm:ethers@^6.15.0"
    },
    "peerDependencies": {
        "@emotion/react": "^11.0.0",
        "@emotion/styled": "^11.0.0",
        "@mui/icons-material": "^5.0.0 || ^6.0.0 || ^7.0.0",
        "@mui/material": "^5.0.0 || ^6.0.0 || ^7.0.0",
        "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
        "viem": "^2.0.0"
    },
    "peerDependenciesMeta": {
        "@emotion/react": {
            "optional": true
        },
        "@emotion/styled": {
            "optional": true
        },
        "@mui/icons-material": {
            "optional": true
        },
        "@mui/material": {
            "optional": true
        },
        "react": {
            "optional": true
        },
        "viem": {
            "optional": true
        }
    },
    "devDependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.6",
        "@mui/material": "^7.3.6",
        "@types/node": "^25.0.3",
        "@types/react": "^18.3.27",
        "react": "^19.2.3",
        "typescript": "^5.0.0",
        "vitest": "^4.0.18"
    },
    "keywords": [
        "insurance",
        "defi",
        "sdk",
        "ethereum",
        "smart-contracts",
        "web3",
        "blockchain",
        "coverage",
        "risk"
    ],
    "author": "LayerCover",
    "license": "MIT"
}
